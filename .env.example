# Núcleo · variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local.

# --- Ambiente ---
NODE_ENV=development

# --- Database (Neon Postgres) ---
# Connection string do branch correspondente (dev / staging / main).
DATABASE_URL=

# --- Auth (Better-Auth) ---
# Gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=

# --- AI (Claude API) ---
ANTHROPIC_API_KEY=

# --- Pagamento (Cakto) ---
CAKTO_API_KEY=
CAKTO_WEBHOOK_SECRET=

# --- Storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- Analytics + Feature Flags (PostHog) ---
# NEXT_PUBLIC_* são expostas ao client — necessário para o SDK posthog-js.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Observabilidade (Sentry) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Background jobs (Trigger.dev) ---
TRIGGER_API_KEY=
